###############################################################################
# Enforce consistent line endings
###############################################################################

* text=auto eol=lf

###############################################################################
# C# and .NET source
###############################################################################

*.cs text
*.razor text
*.csproj text
*.sln text
*.slnx text
*.props text
*.targets text
*.json text
*.xml text
*.yml text
*.yaml text

###############################################################################
# Web files
###############################################################################

*.html text
*.css text
*.js text
*.ts text
*.scss text

###############################################################################
# Shell scripts
###############################################################################

*.sh text eol=lf

###############################################################################
# Windows scripts
###############################################################################

*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# Binary files
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary